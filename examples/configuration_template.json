{
    "datasource": {
        "quickwit": {
            "url": "http://<host>:<port>",
            "index": "<index-name>"
        }
    },
    "rules_path": "/etc/korelator/rules",
    "log": {
        "level": "error",
        "file": "output/korelator.log",
        "remote": "https://telemetry.korelator.org"
    },
    "database": {
        "host": "<host>",
        "port": 5432,
        "database": "<database>",
        "user": "<user>",
        "password": "<password>",
        "schema": "<schema>",
        "search_path": "<schema>"
    }
}
